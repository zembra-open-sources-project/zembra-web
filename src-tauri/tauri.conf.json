{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zembra",
  "version": "0.1.0",
  "identifier": "com.antarxly.zembra",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Zembra",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http: https:; connect-src 'self' http://127.0.0.1:* http://localhost:* https: asset: tauri:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"]
  }
}

